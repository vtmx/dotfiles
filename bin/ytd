#!/usr/bin/env bash

# Verifica yad
if ! command -v yad &>/dev/null; then
  echo 'error: comando yad não encontrado.'
  exit 1
fi

# Verifica comando yt-dlp
if ! command -v yt-dlp &>/dev/null; then
  yad \
  --error \
  --text='Comando yt-dlp não encontrado.' \
  --button='Sair:0'
  exit 1
fi

# Verifica se há algo no clipboard do youtube
if ! xclip -v yt-dlp &>/dev/null; then
  clipboard=$(xclip -o -selection clipboard 2>/dev/null)

  if [[ "$clipboard" =~ https?.*youtu.* ]]; then
    url="$clipboard"
  fi

  url='https://youtu.be/6l-t1uoS-lw?si=eSYXSE6EA-vUxHyr'
fi

while :; do
  output=$(
    yad \
    --form \
    --width=350 \
    --center \
    --window-icon=headphone \
    --image=headphone \
    --separator=' ' \
    --title 'Youtube Download MP3' \
    --text='Youtube MP3' \
    --field='URL' "$url" \
    --field='Pasta:DIR' "$(xdg-user-dir MUSIC)" \
    --button 'Sair:1' --button 'Download:0'
  )

  # Verifica se cancelou ou deu esc
  if [[ $? -eq 1 || $? -eq 252 ]]; then
    exit 0
  fi

  # Recebe valores
  url_chosen=$(cut -d' ' -f1 <<< "$output")
  dir_chosen=$(cut -d' ' -f2 <<< "$output")

  # Check url
  if [[ ! "$url_chosen" =~ https.*youtu.* ]]; then
    yad \
    --error \
    --text="URL não é válida:\n$url_chosen" \
    --button='Sair:1'
    exit 1
  fi

  # Verifica diretório
  if [[ ! -d "$dir_chosen" ]]; then
    yad \
    --error \
    --text="Diretório não é existe:\n$dir_chosen" \
    --button='Sair:1'
    exit 1
  fi

  # Argumentos do yt-dlp
  yt_args=(
    --extract-audio
    --audio-format mp3
    --add-metadata
    --embed-thumbnail
    --progress
    --newline
    --progress-template "%(progress._percent_str)s"
    --no-warnings
    --ignore-errors
    --output "$dir_chosen/%(title)s.%(ext)s"
    "$url_chosen"
  )

  # Exibe janela de download
  (
    (
      yt-dlp "${yt_args[@]}"
      echo -e "\nDownload complete!"
    ) | yad \
    --text-info \
    --width=600 \
    --height=400 \
    --tail \
    --auto-scroll \
    --title='Downloading...' \
    --button='Fechar:0'
  ) &>/dev/null # No msg Theme <Empty> not found

  # Limpa campo de url
  url=''
done

# vim:ft=bash
