#!/usr/bin/env bash

# Youtube download mp3

# Used to remove repetitives dashes
shopt -s extglob

main() {
  if ! command -v yt-dlp &>/dev/null ; then
    echo 'yt-dlp not found'
    exit 1
  fi

  local url=""
  local filename=""
  local time_start=""
  local time_end=""
  local clipboard=$(xclip -o -selection clipboard 2>/dev/null || pbpaste 2>/dev/null || echo "")

  if [[ "$clipboard" =~ https.*youtu.* ]]; then
    url="$clipboard"
  fi

  while (( $# )); do
    case "$1" in
      *youtu*)
        [[ -z "$url" ]] && url="$1"
        shift
        ;;
      # time: 1:23, 01:30, 0:45
      *([0-9]):*([0-9]) | *([0-9]):*([0-9]):*([0-9]) | [0-9][0-9]?:[0-9][0-9] | [0-9]:[0-9][0-9] | [0-9][0-9][0-9])
        if [[ -z "$time_start" ]]; then
          time_start="$1"
        elif [[ -z "$time_end" ]]; then
          time_end="$1"
        fi
        shift
        ;;
      *)
        if [[ "$filename" ]]; then
          filename+=" $1"
        else
          filename="$1"
        fi
        shift
        ;;
    esac
  done

  # Get title of video
  if [[ -z "$filename" ]]; then
    filename=$(yt-dlp --no-warnings --js-runtimes node --print filename -o "%(title)s" "$url")
  fi

  # Transform filename
  filename=$(transform_filename "$filename")

  # Download file
  local args=(
    --extract-audio
    --audio-format mp3
    --restrict-filenames
    --add-metadata
    --embed-thumbnail
    --no-warnings
    --progress-template "Downloading: %(progress._percent_str)s"
    --js-runtimes node
    --remote-components ejs:github
    --output "$filename"
    "$url"
  )

  # Add arg --download-sections if time fill
  if [[ -n "$time_start" ]]; then
    if [[ -n "$time_end" ]]; then
      args+=(--download-sections "*${time_start}-${time_end}")
    else
      args+=(--download-sections "*0:00-${time_start}")
    fi
  fi

  # Command
  yt-dlp "${args[@]}"
}

transform_filename() {
  # Remove chars
  filename="${filename//[\'\"\“\”\[\]\(\)\/\⧸]/}"

  # Replace spaces with dashes
  filename="${filename// /-}"

  # Replace repetitives dashes for one
  filename="${filename//+(-)/-}"

  # Convert to lowercase
  filename="${filename,,}"

  echo "$filename"
}

main "$@"
