#!/usr/bin/env bash

# QT
export QT_QPA_PLATFORMTHEME=qt6ct
export QT_STYLE_OVERRIDE=Oxygen

# Cursor
xsetroot -cursor_name left_ptr & # Need: xorg-xsetroot

# Power
xset s off     # Disable screen saver
xset s noblank # Disable black screen
xset -dpms     # Disable display power management system

# Apps
bspdir=$HOME/.config/bspwm
pgrep -x sxhkd    > /dev/null || sxhkd -c $bspdir/shortcuts &
pgrep -x numlockx > /dev/null || numlockx & # Need nunlockx
pgrep -x feh      > /dev/null || feh --no-fehbg --bg-fill --recursive --randomize $bspdir/wall/ &
pgrep -x polybar  > /dev/null || polybar bottom -c $bspdir/polybar/config.ini &
pgrep -x dunst    > /dev/null || dunst -config $bspdir/dunst/dunstrc &
# pgrep -x picom > /dev/null || picom --config $bspdir/picom/picom.conf &
pgrep -f /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 > /dev/null || /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
