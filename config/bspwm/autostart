#!/usr/bin/env bash

# QT
export QT_QPA_PLATFORMTHEME=qt6ct
export QT_STYLE_OVERRIDE=Oxygen

# bspwm config dir
bspdir=$HOME/.config/bspwm

start() {
  local proc=$(basename "$1")
  pgrep -x "$proc" >/dev/null || "$@" &
}

# Apps
xsetroot -cursor_name left_ptr &
xset s off noblank -dpms &
start numlockx
start sxhkd -c $bspdir/shortcuts
start dunst -config $bspdir/dunst/dunstrc
start feh --no-fehbg --bg-fill --recursive --randomize $bspdir/wall/
start polybar bottom -c $bspdir/polybar/config.ini
start /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
# start picom --config $bspdir/picom/picom.conf
