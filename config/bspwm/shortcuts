# Toggle polybar
super + shift + b
  $HOME/.config/bspwm/polybar/scripts/toggle

# Close or kill window
super + {_,shift + }c
  bspc node -{c,k}

# Toggle fullscreen
super + f
  bspc node -t '~'{tiled,fullscreen}

# Toggle floating
super + shift + f
  bspc node -t '~'{floating,tiled}

# Stick window always top
super + shift + p
  bspc node -g sticky

# Quit
super + shift + q
  bspc quit

# Run
super + r
  rofi -show run -display-run '' -config $HOME/.config/bspwm/rofi/config.rasi

# Reload
super + shift + r
  bspc wm -r && pkill -USR1 -x sxhkd && notify-send -u low -t 1500 'bspwm' 'Reloaded'

# Toggle compositor
super + shift + u
  pkill -x picom || picom --config $HOME/.config/bspwm/picom/picom.conf

# Ux compositor
super + u ; {b,f,o,r,s}
  pkill -x picom || \
  picom --config $HOME/.config/bspwm/picom/picom.conf \
  {--blur-method gaussian --blur-strength 8,--fading,--inactive-opacity 0.8,--corner-radius 8,--shadow}

# Change wallpaper
super + shift + w
  feh --no-fehbg --bg-fill --recursive --randomize $HOME/.config/bspwm/wall/**

# Edit o reload config or shortcuts
super + {_,shift + } + {comma,period}
  {\
    kitty -e nvim $HOME/.config/bspwm/bspwmrc, \
    bspc wm -r && pkill -USR1 -x sxhkd && notify-send -u low -t 1500 'bspwm' 'Reloaded', \
    kitty -e nvim $HOME/.config/bspwm/shortcuts, \
    pkill -USR1 -x sxhkd && notify-send 'sxhkd' 'Reloaded', \
  }

# Window

# Focus
super + {h,Left,j,Down,k,Up,l,Right}
  bspc node -f {west,west,south,south,north,north,east,east}

# Swap or move
super + shift + {h,Left,j,Down,k,Up,l,Right}
  $HOME/.config/bspwm/swapmove {west,west,south,south,north,north,east,east}

# Focus next, prev local node
alt + {_,shift + }Tab
  bspc node -f {next,prev}.local

# Resize
super + alt + {h,Left,j,Down,k,Up,l,Right}
  $HOME/.config/bspwm/resize {west,west,south,south,north,north,east,east} 50

# Workspace

# Focus or send to prev or next desktop
super + ctrl + {_,shift + }{h,Left,l,Right}
  bspc {desktop -f,node -d} {prev,prev,next,next}.local --follow

# Focus or send node to desktop
super + {_,shift + }{1-9}
  bspc {desktop -f,node -d} '^{1-9}' --follow

super + {_,shift + }KP_{End,Down,Next,Left,Begin,Right,Home,Up,Prior}
  bspc {desktop -f,node -d} '^{1,2,3,4,5,6,7,8,9}' --follow

# Send node to desktop
super + ctrl + {1-9}
  bspc node -d '^{1-9}'

super + ctrl + KP_{End,Down,Next,Left,Begin,Right,Home,Up,Prior}
  bspc node -d '^{1,2,3,4,5,6,7,8,9}'

# Apps
super + {a,b,e,g,p,t,s,v}
  {pamac-manager,zen-browser,thunar,steam,kcolorchooser,qbittorrent,flameshot gui,code}

# Alternate
super + alt + {b,e,p}
  {firefox,thunar,bitwarden-desktop}

# Terminal
super + {_,alt + }Return
  term=kitty; {$term,bspc rule -a \* -o state=floating && $term}

# Launcher
super + space
  rofi -show drun -config $HOME/.config/bspwm/rofi/config.rasi

# Change volume
super + {equal,minus,0}
  step=10; \
  amixer -q set Master {$step%+, $step%-, toggle} && \
  notify-send 'Volume' $(awk -F'[][]' '/Left:/ \{print $2\}' <(amixer sget Master))

# Powermenu
ctrl + alt + Delete
  $HOME/.config/bspwm/powermenu

# Screenshot
Print
  flameshot gui

# Mouse
~button3
  if ! bspc query -N -d focused; then \
    jgmenu --config-file=$HOME/.config/bspwm/jgmenu/jgmenurc; \
  fi

